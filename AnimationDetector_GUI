-- Helper: add row to list
local rowCount = 0
local rows = {}

local function addRow(id, isNew)
    if rows[id] then
        rows[id].BackgroundColor3 = Color3.fromRGB(30, 55, 80)
        task.delay(0.3, function()
            if rows[id] then
                rows[id].BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            end
        end)
        return
    end

    rowCount += 1
    local row = Instance.new("Frame")
    row.Name             = "Row_" .. rowCount
    row.Size             = UDim2.new(1, 0, 0, 22)
    row.BackgroundColor3 = isNew and Color3.fromRGB(30, 55, 80) or Color3.fromRGB(18, 18, 18)
    row.BorderSizePixel  = 0
    row.LayoutOrder      = rowCount
    row.Parent           = scrollFrame

    local idText = Instance.new("TextLabel")
    idText.Size                   = UDim2.new(1, -8, 1, 0)
    idText.Position               = UDim2.new(0, 6, 0, 0)
    idText.BackgroundTransparency = 1
    idText.Text                   = id
    idText.TextColor3             = Color3.fromRGB(160, 200, 220)
    idText.TextSize               = 10
    idText.Font                   = Enum.Font.Code
    idText.TextXAlignment         = Enum.TextXAlignment.Left
    idText.TextTruncate           = Enum.TextTruncate.AtEnd
    idText.Parent                 = row

    rows[id] = row

    if isNew then
        task.delay(1.0, function()
            if rows[id] then
                rows[id].BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            end
        end)
    end
end

-- Main tracking logic
local function startTracking(char)
    rows     = {}
    rowCount = 0

    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local humanoid = char:WaitForChild("Humanoid", 10)
    if not humanoid then return end
    local animator = humanoid:WaitForChild("Animator", 10)
    if not animator then return end

    animator.AnimationPlayed:Connect(function(track)
        local id = track.Animation and track.Animation.AnimationId or "rbxassetid://unknown"
        print(string.format("[ANIM PLAY] %s  (%.3fs)", id, track.Length))
        currentIdLabel.Text = id
        addRow(id, true)
    end)

    RunService.Heartbeat:Connect(function()
        local tracks = animator:GetPlayingAnimationTracks()
        if #tracks == 0 then
            progressFill.Size  = UDim2.new(0, 0, 1, 0)
            progressLabel.Text = "0.000/0.000 (0ms)"
            return
        end

        local best = tracks[1]
        for _, t in ipairs(tracks) do
            if t.WeightCurrent > best.WeightCurrent then
                best = t
            end
        end

        local pos = best.TimePosition
        local len = best.Length > 0 and best.Length or 1
        local pct = pos / len

        progressFill.Size  = UDim2.new(pct, 0, 1, 0)
        progressLabel.Text = string.format(
            "%.3f/%.3f (%dms)",
            pos, len, math.floor(pos * 1000)
        )

        local id = best.Animation and best.Animation.AnimationId or "rbxassetid://--"
        currentIdLabel.Text = id
    end)

    print("[AnimDetector] Tracking started.")
end

local char = player.Character or player.CharacterAdded:Wait()
task.wait(0.5)
startTracking(char)

player.CharacterAdded:Connect(function(newChar)
    task.wait(0.5)
    startTracking(newChar)
end)
